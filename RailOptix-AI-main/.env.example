# RailOptix AI - Backend Configuration Options
PORT=8000
HOST=0.0.0.0

# Database URL for SQLite (local testing)
# DATABASE_URL=sqlite:///./railoptix.db

# Database URL for MySQL (production/Render deployment)
# Format: mysql://username:password@hostname:port/database_name
# Note: The PyMySQL driver (mysql+pymysql://) is handled automatically by connection.py
DATABASE_URL=mysql://db_user:db_password@localhost:3306/railoptix_db
